    <!-- ================= QUICK STATS ================= -->
    <section class="stats">
        <div class="stat-card"><h2>5+</h2><p>Projects Built</p></div>
        <div class="stat-card"><h2>6+</h2><p>Programming Skills</p></div>
        <div class="stat-card"><h2>100%</h2><p>Passion for Coding</p></div>
        <div class="stat-card"><h2>∞</h2><p>Learning Never Stops</p></div>
