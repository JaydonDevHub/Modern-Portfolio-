            <div class="floating-tech css"><i class="fa-brands fa-css3-alt"></i></div>
            <div class="floating-tech js"><i class="fa-brands fa-js"></i></div>
            <div class="floating-tech python"><i class="fa-brands fa-python"></i></div>
            <div class="floating-tech java"><i class="fa-brands fa-java"></i></div>
        </div>
