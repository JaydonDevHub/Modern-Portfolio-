    <!-- ================= HERO ================= -->
    <section id="home" class="hero">
        <div class="hero-bg">
            <span class="circle one"></span>
            <span class="circle two"></span>
            <span class="circle three"></span>
        </div>
        <div class="hero-content">
            <div class="availability"><span class="dot"></span>Available for Freelance</div>
            <h3>👋 Hello, I'm</h3>
            <h1>Michael <span>Waweru</span></h1>
            <h2><span id="typing"></span></h2>
            <p>I design and build beautiful websites, modern web applications and software solutions that provide exceptional user experiences.</p>
            <div class="hero-buttons">
                <a href="#projects" class="btn"><i class="fa-solid fa-code"></i> View Projects</a>
                <a href="#contact" class="btn-outline"><i class="fa-solid fa-paper-plane"></i> Hire Me</a>
            </div>
            <div class="social-icons">
                <a href="#"><i class="fab fa-github"></i></a>
                <a href="#"><i class="fab fa-linkedin"></i></a>
                <a href="#"><i class="fab fa-x-twitter"></i></a>
                <a href="#"><i class="fab fa-instagram"></i></a>
            </div>
        </div>
        <div class="hero-image">
            <img src="assets/images/profile.png" alt="Michael Waweru">
